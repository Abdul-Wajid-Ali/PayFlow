        }
      }
    ]
  },
  "Redis": {
    "ConnectionString": "localhost:6379"
  },
  "RateLimiting": {
    "Transfer": {
      "PermitLimit": 5,
      "WindowSeconds": 60,
      "QueueLimit": 0
