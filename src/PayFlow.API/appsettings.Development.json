{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\MSSQLLocalDB;Database=PayFlow;Trusted_Connection=True;MultipleActiveResultSets=True"
  },
  "JwtSettings": {
    "SecretKey": "dAJadZkUzk3hN7jvmV8sjxXFFRRTFwoxP2dRZrNoG44,",
    "Issuer": "PayFlow.API",
    "Audience": "PayFlow.Client",
    "ExpiryInMinutes": 60,
    "RefreshTokenExpiryInDays": 14
